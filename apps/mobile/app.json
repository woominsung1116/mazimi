{
  "expo": {
    "name": "마지미",
    "slug": "mazimi",
    "version": "1.0.0",
    "owner": "wooms",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mazimi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/225a8c33-91f4-4993-beb6-1114b74b58fa"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5CB1A7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kr.mazimi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5CB1A7"
      },
      "package": "kr.mazimi.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "225a8c33-91f4-4993-beb6-1114b74b58fa"
      },
      "router": {
        "origin": false
      }
    }
  }
}
