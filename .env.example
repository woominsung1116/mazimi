# =============================================================================
# Database (Supabase managed PG in production)
# =============================================================================
DATABASE_URL=postgres://wello:wello@db:5432/wello
DB_PASSWORD=wello_secret
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://redis:6379

# =============================================================================
# Auth
# =============================================================================
JWT_SECRET=change-me-in-production
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# =============================================================================
# AI
# =============================================================================
AI_PROVIDER=openai_compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_SUMMARY=
AI_MODEL_REASONING=

# =============================================================================
# API Keys (공공데이터포털 / 외부 API)
# =============================================================================
# data.go.kr 일반 공공 API 디코딩 키
GOV_API_KEY=your_data_go_kr_decoding_key
# 복지로 혜택 API 키
GOV_BENEFITS_API_KEY=your_data_go_kr_decoding_key
# 청년정책포털 API 키
YOUTH_CENTER_API_KEY=your_youth_center_api_key
# 워크넷 API 키
WORKNET_API_KEY=your_data_go_kr_decoding_key
# 한국장학재단(KOSAF) API 키
KOSAF_API_KEY=your_data_go_kr_decoding_key
# 금융감독원(FSS) API 키
FSS_API_KEY=your_fss_api_key

# =============================================================================
# Worker — Notifications
# =============================================================================
# Kakao Alimtalk (카카오 비즈메시지)
KAKAO_BIZ_API_KEY=
KAKAO_BIZ_SENDER_KEY=
KAKAO_ALIMTALK_TEMPLATE_CODE=

# Firebase Cloud Messaging (FCM)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
FCM_ACCESS_TOKEN=your_fcm_token

# Worker — Scraper
SCRAPER_ENABLED=false
SCRAPER_TIMEOUT_SECS=20
# 한국사회보장정보원 복지서비스 API (data.go.kr 디코딩 키)
NATIONAL_WELFARE_API_KEY=your_data_go_kr_decoding_key
LOCAL_WELFARE_API_KEY=your_data_go_kr_decoding_key

# Callback base host (used by worker to build webhook/redirect URLs)
CALLBACK_HOST=localhost

# =============================================================================
# App
# =============================================================================
APP_ENV=local
APP_PORT=8080
DOMAIN=localhost
RUST_LOG=info

# =============================================================================
# Mobile (Expo / React Native)
# =============================================================================
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_KAKAO_CLIENT_ID=your_kakao_client_id
